# GT Workflows Manager Configuration

# Set the path to your workflows directory
# Can be absolute (e.g., C:\path\to\workflows or /path/to/workflows)
# or relative to the project root
GT_WORKFLOWS_PATH=../data/gt-workflows

# Optional: Directory for user preferences (dashboard UI state: anonymise, servers list open, etc.).
# One JSON file per user. Default: data/preferences
# GT_PREFERENCES_PATH=../data/preferences

# Optional: HTTP Basic Auth (login screen)
# Set GT_WF_AUTH=false to disable auth (no login, no token check, logout button hidden).
# When true or unset, auth is enabled if any credential pair is set (admin and/or guest).
# The logged-in username is shown next to the logout button.
# In production, serve over HTTPS so credentials in the Authorization header are not exposed (MITM).
# GT_WF_AUTH=false
# GT_WF_ADMIN_USER=admin
# GT_WF_ADMIN_PASSWORD=your-secure-password
# GT_WF_GUEST_USER=guest
# GT_WF_GUEST_PASSWORD=guest-password

# Optional: When set (true or 1), user names in Job stats are anonymised for guest users only
# (e.g. john.doe → j**.**e: first letter + "**.**" + last letter).
# GT_WF_ANONYMIZE_JOB_STATS_USERS=true

# Optional: Session timeout in seconds. User is logged out after this period of inactivity.
# Default: 86400 (24 hours). Only applies when auth is enabled.
# SESSION_MAX_TIME=86400

# Optional: Job stats dashboard (Bull queue used by Workflow Studio)
# Redis connection URL for direct queue access (same as backend service uses)
# Format: redis://[password@]host:port[/db]
# REDIS_URL=redis://localhost:6379
# BULL_QUEUE_NAME=workflow-studio-comfyui-process-queue
